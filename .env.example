PORT=3000
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_CHAT_ID=your_admin_chat_id

# Bot mode: polling for local dev, webhook for production
BOT_MODE=polling
TELEGRAM_WEBHOOK_URL=https://your-domain.com

# AI
ENABLE_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# PayOS (optional in local dev)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=https://your-domain.com/payment/success
PAYOS_CANCEL_URL=https://your-domain.com/payment/cancel

# Redis (used for buyer session)
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=86400
